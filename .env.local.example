# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional — override the Claude model used (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — Vercel KV (Redis) for persistent unit storage across deployments.
# Without this, units are saved to .db.json locally (not persisted on Vercel).
# Add a KV database in your Vercel project dashboard; it auto-populates these.
# KV_REST_API_URL=https://your-kv.upstash.io
# KV_REST_API_TOKEN=your_kv_token_here
